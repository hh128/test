{
    "name": "eventswidget-playwright-test",
    "version": "1.0.0",
    "description": "Automated test for https://dev.3snet.info/eventswidget/ using Playwright (Advanced Level)",
    "main": "index.js",
    "scripts": {
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:headed": "playwright test --headed",
        "report": "allure generate ./allure-results --clean && allure open ./allure-report",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write .",
        "dashboard": "node server.js"
    },
    "keywords": [
        "playwright",
        "testing",
        "automation",
        "e2e",
        "allure"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.42.0",
        "@types/node": "^20.11.24",
        "@typescript-eslint/eslint-plugin": "^7.1.0",
        "@typescript-eslint/parser": "^7.1.0",
        "allure-commandline": "^2.27.0",
        "allure-playwright": "^2.14.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-playwright": "^1.5.1",
        "prettier": "^3.2.5",
        "typescript": "^5.3.3"
    }
}